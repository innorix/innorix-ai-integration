# ==========================================================
# INNORIX AI Integration
# Environment Variables
#
# Copy this file to ".env" and update the values for your
# environment.
# ==========================================================

# ==========================================================
# INNORIX Platform
# ==========================================================

INNORIX_SERVER=https://your-innorix-server.example.com
INNORIX_API_KEY=YOUR_API_KEY
INNORIX_AGENT_ID=YOUR_AGENT_ID

# ==========================================================
# Logging
# ==========================================================

LOG_LEVEL=INFO
LOG_DIRECTORY=./logs
